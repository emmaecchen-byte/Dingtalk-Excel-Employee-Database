# PostgreSQL (production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dingtalk_attendance

# SQLite (local demo fallback)
# DATABASE_URL=sqlite:///./attendance.db

# Connection pool (PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# JWT authentication (required for login sessions)
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend origin (CORS + OAuth redirect target after DingTalk login)
FRONTEND_URL=http://172.16.40.20:5173
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://172.16.40.20:5173","http://172.16.40.20:8000"]

DEMO_MODE=true

# --- DingTalk OAuth (required for "Login with DingTalk") ---
# Create an app at https://open.dingtalk.com and register the redirect URI below.
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
# Your enterprise corp ID (recommended; also returned when scope includes corpid)
DINGTALK_CORP_ID=
# Must match the callback URL registered in the DingTalk developer console
DINGTALK_REDIRECT_URI=http://127.0.0.1:8000/api/auth/dingtalk/callback

# DingTalk employee sync API (uses same CLIENT_ID / CLIENT_SECRET)
DINGTALK_ROOT_DEPARTMENT_ID=1
DINGTALK_API_DELAY_MS=200

# DingTalk webhook callbacks (HTTP push for attendance/leave events)
DINGTALK_WEBHOOK_SECRET=
DINGTALK_WEBHOOK_TOKEN=
DINGTALK_WEBHOOK_AES_KEY=
DINGTALK_WEBHOOK_OWNER_KEY=

# Webhook security (optional)
# Reject callbacks when X-DingTalk-Timestamp is older than this many seconds (default 300)
WEBHOOK_TIMESTAMP_MAX_SKEW_SECONDS=300
# Comma-separated allowlist; leave empty to allow any source IP
# WEBHOOK_ALLOWED_IPS=1.2.3.4,5.6.7.8
